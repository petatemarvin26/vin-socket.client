{
  "ts-node": {
    "require": ["tsconfig-paths/register"]
  },
  "compilerOptions": {
    "baseUrl": "src",
    "outDir": "./lib",
    "target": "ES6",
    "module": "CommonJS",
    "moduleResolution": "node"
  },
  "include": ["./src/**/*", "*.ts", "package.json"],
  "exclude": ["node_modules"]
}
